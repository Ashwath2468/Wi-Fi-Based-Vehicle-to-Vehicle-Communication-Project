// Server Side Sensors----
#include <ESP8266WiFi.h>
#include "ESPAsyncWebServer.h"
#include<LiquidCrystal_I2C.h>

LiquidCrystal_I2C lcd(0X27 , 16 , 2);
const char* ssid = "ESPAP";
const char* password = "123456789";

AsyncWebServer server(80);

int Echo = D6, Trig = D5;
int AlcoholSensor = D4;
int Right = D0, Left = D3 , Stop = D7;
int buzzer = D8;
int VibrationSensor = A0;
int D = 0, AlcoholValue = 0, VibrationValue = 0;
String Direction = "";

int MotorEn = 3;
bool VibrationFlag = 0, ObjectFlag = 0, AlcoholFlag = 0, StopFlag = 0;

void GetDistance()
{
  digitalWrite(Trig , HIGH);
  delayMicroseconds(10);
  digitalWrite(Trig , LOW);
  int t = pulseIn(Echo , HIGH);
  D = t / 58.77;
  //  Serial.println("Distance:" + String(D));
  if (D < 50)
  {
     digitalWrite(buzzer , HIGH);
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Alert....!Object");
    lcd.setCursor(0, 1);
    lcd.print("    Detected    ");
    delay(1000);
    digitalWrite(buzzer , LOW);
  }
  else
  {
    ObjectFlag = 0;
  }
}

void GetAlcohol()
{
  AlcoholValue = digitalRead(AlcoholSensor);
  //  Serial.println("Alcohol val: " + String(AlcoholValue));
  if (AlcoholValue == 0)
  {
    digitalWrite(buzzer , HIGH);
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Alert....!");
    lcd.setCursor(0, 1);
    lcd.print("Driver Alcoholic");
    delay(1000);
    digitalWrite(buzzer , LOW);
  }
  else
  {
    AlcoholFlag = 0;
  }
}

void GetVibration()
{
  VibrationValue = analogRead(VibrationSensor);
  //  Serial.println("Vibration : " + String(VibrationValue));
  if (VibrationValue > 500)
  {
    digitalWrite(buzzer , HIGH);
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Alert..!Accident");
    lcd.setCursor(0, 1);
    lcd.print("    Detected    ");
    delay(1000);
    digitalWrite(buzzer , LOW);
  }
  else
  {
    VibrationFlag = 0;
  }
}

void GetDirection()
{

  //  Serial.print(digitalRead(Right));
  //  Serial.print(digitalRead(Left));
  //  Serial.print(digitalRead(Stop));
  if (digitalRead(Right) == 0)
  {
    Direction = "Right";
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Direction:" + Direction);
  }
  else if (digitalRead(Left) == 0)
  {
    Direction = "Left";
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Direction:" + Direction);
  }
  else if (digitalRead(Stop) == 0)
  {
    Direction = "Stop";
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Direction:" + Direction);
    StopFlag = 1;
  }
  else
  {
    Direction = "";
    StopFlag = 0;
  }
  //  Serial.println("Direction: " + Direction);

}

String readDistance()
{
  return String(23);
}

String readAlcohol()
{
  return String(45);
}

String readVibration() {
  return String(13);
}

String readDirection()
{
  return Direction;
}

void setup() {
  //  Serial.begin(115200);
  pinMode(buzzer , OUTPUT);
  pinMode(Trig , OUTPUT);
  pinMode(Echo , INPUT);
  pinMode(Right , INPUT);
  pinMode(Left , INPUT);
  pinMode(Stop , INPUT);
  pinMode(MotorEn , OUTPUT);
  digitalWrite(MotorEn , LOW);
  pinMode(AlcoholSensor , INPUT);
  digitalWrite(buzzer , LOW);
 delay(3000); // let DHCP & AP service stabilize

  IPAddress IP = WiFi.softAPIP();
  //  Serial.print("AP IP address: ");
  //  Serial.println(IP);  // should print 192.168.4.1
